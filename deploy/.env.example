# Copy to deploy/.env and fill in values before: docker compose -f deploy/docker-compose.yml up --build

# Required — proxy rejects unauthenticated requests when set
LITELLM_MASTER_KEY=change-me-to-a-long-random-secret

# OpenRouter enrichment for model discovery (use "dummy" for offline/test regen only)
OPENROUTER_API_KEY=

# Optional provider keys (only needed if alias chain routes through these providers)
OPENAI_API_KEY=
GROQ_API_KEY=

# Optional — skip live provider fetches during config generation
# LITELLM_LOCAL_MODEL_COST_MAP=true

# Optional — sidecar refresh interval (seconds); default 21600 (6h)
# UPDATE_INTERVAL_SECONDS=21600

# Optional — Postgres for LiteLLM spend logs (leave empty for minimal local deploy)
# DATABASE_URL=
