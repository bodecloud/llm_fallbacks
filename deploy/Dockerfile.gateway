# Production LiteLLM gateway for free PaaS (Render, Koyeb, etc.).
# Build context: repository root.

FROM python:3.12-slim-bookworm

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt setup.py pyproject.toml README.md ./
COPY src ./src

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt \
    && pip install --no-cache-dir -e . \
    && pip install --no-cache-dir "litellm[proxy]"

COPY deploy/scripts/start-gateway.sh /app/deploy/scripts/start-gateway.sh
RUN chmod +x /app/deploy/scripts/start-gateway.sh

ENV PYTHONUNBUFFERED=1
ENV CONFIG_DIR=/config
ENV PORT=4000

EXPOSE 4000

HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
  CMD curl -f "http://127.0.0.1:${PORT}/health/liveliness" || exit 1

CMD ["/app/deploy/scripts/start-gateway.sh"]
